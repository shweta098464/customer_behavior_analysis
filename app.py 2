import pandas as pd
import plotly.express as px

# ---------------- PAGE CONFIG ----------------
st.set_page_config(
    page_title="Shopping Dashboard",
    page_icon="🛒",
    layout="wide"
)

# ---------------- CUSTOM THEME ----------------
